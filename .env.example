# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: model id for generateContent (default: gemini-2.5-flash).
# Use names from the API — older ids like gemini-1.5-flash return 404 on current v1beta.
# Examples: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash
# GEMINI_MODEL="gemini-2.5-flash"
#
# Optional: comma-separated fallback model ids (order preserved). On rate limit / quota for
# GEMINI_MODEL, the learning assistant tries each fallback in order.
# GEMINI_MODEL_FALLBACK="gemini-2.5-flash-lite, gemini-2.0-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Contact form (Web3Forms — https://web3forms.com): create a form and set the inbox that should
# receive messages there. Paste only the public access key here; your email is never in client code.
VITE_WEB3FORMS_ACCESS_KEY=""
