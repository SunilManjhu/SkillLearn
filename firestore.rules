rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: votes
    // Document ID: auto-generated
    // Fields:
    //   - lessonId: string (required) - The ID of the lesson.
    //   - userId: string (required) - The UID of the voter.
    //   - type: string (required, enum: ['up', 'down']) - Vote type.
    //   - timestamp: timestamp (required) - When cast.
    //
    // Collection: suggestions
    // Document ID: auto-generated
    // Fields:
    //   - lessonId: string (required) - The ID of the lesson.
    //   - userId: string (required) - The UID of the suggester.
    //   - suggestedUrl: string (required) - The YouTube URL.
    //   - timestamp: timestamp (required) - When made.
    //
    // Collection: customizations
    // Document ID: auto-generated
    // Fields:
    //   - lessonId: string (required) - The ID of the lesson.
    //   - userId: string (required) - The UID of the user.
    //   - customUrl: string (required) - The personal YouTube URL replacement.
    //   - timestamp: timestamp (required) - When made.
    //
    // Collection: reports
    // Document ID: auto-generated
    // Fields:
    //   - lessonId: string (required) - The ID of the lesson.
    //   - userId: string (required) - The UID of the reporter.
    //   - reason: string (required, enum: ['Technical issue', 'Misinformation', 'Spam or misleading', 'Legal issue', 'Confusing']) - Report reason.
    //   - details: string (optional) - Additional details.
    //   - timestamp: timestamp (required) - When made.
    //
    // Collection: certificates
    // Document ID: certificateId
    // Fields:
    //   - courseId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - date: timestamp (required)
    //   - certificateId: string (required)
    //
    // Collection: progress
    // Document ID: userId_courseId
    // Fields:
    //   - courseId: string (required)
    //   - userId: string (required)
    //   - lessonProgress: map (required)
    //   - lastUpdated: timestamp (required)
    //   - completedAt: timestamp (optional) - When the course was marked complete
    //
    // Collection: courseRatings
    // Document ID: userId_courseId
    // Fields:
    //   - courseId: string (required)
    //   - userId: string (required)
    //   - stars: int (required, 1-5)
    //   - comment: string (optional)
    //   - submittedAt: timestamp (required)
    //
    // Collection: contactMessages
    // Document ID: auto-generated
    // Fields:
    //   - subject: string (required)
    //   - message: string (required)
    //   - userId: string (required) - submitter UID
    //   - senderEmail: string (required, may be empty when token has no email)
    //   - senderDisplayName: string (required, may be empty)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasAdminRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // UID fallback: rules must agree the user is admin; if hasAdminRole/email checks ever diverge
    // from the client (wrong DB in Console, token shape, etc.), this still allows known admins.
    function isAdmin() {
      return isAuthenticated() && (
        hasAdminRole() ||
        (request.auth.token.email.lower() == "ranveer.singh.blr@gmail.com" && request.auth.token.email_verified == true) ||
        request.auth.uid == "Uz4Ctf9ThuV7BumSU8T8xAe1qt42"
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidVote(data) {
      return hasRequiredFields(['lessonId', 'userId', 'type', 'timestamp']) &&
             hasOnlyAllowedFields(['lessonId', 'userId', 'type', 'timestamp']) &&
             data.lessonId is string && data.lessonId.size() > 0 && data.lessonId.size() < 100 &&
             data.userId == request.auth.uid &&
             data.type in ['up', 'down'] &&
             data.timestamp is timestamp;
    }

    function isValidSuggestion(data) {
      return hasRequiredFields(['lessonId', 'userId', 'suggestedUrl', 'timestamp']) &&
             hasOnlyAllowedFields(['lessonId', 'userId', 'suggestedUrl', 'timestamp']) &&
             data.lessonId is string && data.lessonId.size() > 0 && data.lessonId.size() < 100 &&
             data.userId == request.auth.uid &&
             isValidUrl(data.suggestedUrl) && data.suggestedUrl.size() < 500 &&
             data.timestamp is timestamp;
    }

    function isValidCustomization(data) {
      return hasRequiredFields(['lessonId', 'userId', 'customUrl', 'timestamp']) &&
             hasOnlyAllowedFields(['lessonId', 'userId', 'customUrl', 'timestamp']) &&
             data.lessonId is string && data.lessonId.size() > 0 && data.lessonId.size() < 100 &&
             data.userId == request.auth.uid &&
             isValidUrl(data.customUrl) && data.customUrl.size() < 500 &&
             data.timestamp is timestamp;
    }

    function isValidReport(data) {
      return hasRequiredFields(['lessonId', 'userId', 'reason', 'timestamp']) &&
             hasOnlyAllowedFields([
               'lessonId',
               'courseId',
               'courseTitle',
               'lessonTitle',
               'userId',
               'reason',
               'details',
               'timestamp'
             ]) &&
             data.lessonId is string && data.lessonId.size() > 0 && data.lessonId.size() < 100 &&
             (!('courseId' in data) || (data.courseId is string && data.courseId.size() > 0 && data.courseId.size() < 200)) &&
             (!('courseTitle' in data) || (data.courseTitle is string && data.courseTitle.size() > 0 && data.courseTitle.size() < 500)) &&
             (!('lessonTitle' in data) || (data.lessonTitle is string && data.lessonTitle.size() > 0 && data.lessonTitle.size() < 500)) &&
             data.userId == request.auth.uid &&
             data.reason in ['Technical issue', 'Misinformation', 'Spam or misleading', 'Legal issue', 'Confusing'] &&
             (!('details' in data) || (data.details is string && data.details.size() < 2000)) &&
             data.timestamp is timestamp;
    }

    function isValidCertificate(data) {
      return hasRequiredFields(['courseId', 'userId', 'userName', 'date', 'certificateId']) &&
             hasOnlyAllowedFields(['courseId', 'userId', 'userName', 'date', 'certificateId']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() < 100 &&
             data.courseId is string &&
             data.date is timestamp &&
             data.certificateId is string;
    }

    function isValidProgress(data) {
      return hasRequiredFields(['courseId', 'userId', 'lessonProgress', 'lastUpdated']) &&
             hasOnlyAllowedFields(['courseId', 'userId', 'lessonProgress', 'lastUpdated', 'completedAt']) &&
             data.userId == request.auth.uid &&
             data.courseId is string &&
             data.lessonProgress is map &&
             data.lastUpdated is timestamp &&
             (!('completedAt' in data) || data.completedAt is timestamp);
    }

    function isValidCourseRating(data) {
      return hasRequiredFields(['courseId', 'userId', 'stars', 'submittedAt']) &&
             hasOnlyAllowedFields(['courseId', 'userId', 'stars', 'comment', 'submittedAt']) &&
             data.userId == request.auth.uid &&
             data.courseId is string && data.courseId.size() > 0 && data.courseId.size() < 200 &&
             data.stars in [1, 2, 3, 4, 5] &&
             (!('comment' in data) || (data.comment is string && data.comment.size() < 2000)) &&
             data.submittedAt is timestamp;
    }

    function validQuizAttemptQuestionEntry(e) {
      return e is map &&
             e.keys().hasAll(['questionId', 'type', 'score']) &&
             e.keys().hasOnly(['questionId', 'type', 'score', 'correct', 'chosenIndex', 'aiFeedback']) &&
             e.questionId is string && e.questionId.size() > 0 && e.questionId.size() < 200 &&
             e.type in ['mcq', 'freeform'] &&
             e.score is number && e.score >= 0 && e.score <= 100 &&
             (!('correct' in e) || e.correct is bool) &&
             (!('chosenIndex' in e) || (e.chosenIndex is int && e.chosenIndex >= 0 && e.chosenIndex < 64)) &&
             (!('aiFeedback' in e) || (e.aiFeedback is string && e.aiFeedback.size() < 8000));
    }

    function validQuizAttemptPerQuestionList(q) {
      return q is list && q.size() > 0 && q.size() <= 20 &&
             (q.size() < 1 || validQuizAttemptQuestionEntry(q[0])) &&
             (q.size() < 2 || validQuizAttemptQuestionEntry(q[1])) &&
             (q.size() < 3 || validQuizAttemptQuestionEntry(q[2])) &&
             (q.size() < 4 || validQuizAttemptQuestionEntry(q[3])) &&
             (q.size() < 5 || validQuizAttemptQuestionEntry(q[4])) &&
             (q.size() < 6 || validQuizAttemptQuestionEntry(q[5])) &&
             (q.size() < 7 || validQuizAttemptQuestionEntry(q[6])) &&
             (q.size() < 8 || validQuizAttemptQuestionEntry(q[7])) &&
             (q.size() < 9 || validQuizAttemptQuestionEntry(q[8])) &&
             (q.size() < 10 || validQuizAttemptQuestionEntry(q[9])) &&
             (q.size() < 11 || validQuizAttemptQuestionEntry(q[10])) &&
             (q.size() < 12 || validQuizAttemptQuestionEntry(q[11])) &&
             (q.size() < 13 || validQuizAttemptQuestionEntry(q[12])) &&
             (q.size() < 14 || validQuizAttemptQuestionEntry(q[13])) &&
             (q.size() < 15 || validQuizAttemptQuestionEntry(q[14])) &&
             (q.size() < 16 || validQuizAttemptQuestionEntry(q[15])) &&
             (q.size() < 17 || validQuizAttemptQuestionEntry(q[16])) &&
             (q.size() < 18 || validQuizAttemptQuestionEntry(q[17])) &&
             (q.size() < 19 || validQuizAttemptQuestionEntry(q[18])) &&
             (q.size() < 20 || validQuizAttemptQuestionEntry(q[19]));
    }

    function isValidQuizAttempt(data) {
      return hasRequiredFields(['userId', 'courseId', 'lessonId', 'submittedAt', 'overallScore', 'perQuestion']) &&
             hasOnlyAllowedFields(['userId', 'courseId', 'lessonId', 'submittedAt', 'overallScore', 'perQuestion']) &&
             data.userId == request.auth.uid &&
             data.courseId is string && data.courseId.size() > 0 && data.courseId.size() < 200 &&
             data.lessonId is string && data.lessonId.size() > 0 && data.lessonId.size() < 200 &&
             data.submittedAt is timestamp &&
             data.overallScore is number && data.overallScore >= 0 && data.overallScore <= 100 &&
             validQuizAttemptPerQuestionList(data.perQuestion);
    }

    function contactSenderEmailMatchesToken(data) {
      return (request.auth.token.email is string && request.auth.token.email.size() > 0)
        ? (data.senderEmail is string && data.senderEmail == request.auth.token.email)
        : (data.senderEmail is string && data.senderEmail.size() == 0);
    }

    function isValidContactMessage(data) {
      return hasRequiredFields(['subject', 'message', 'userId', 'timestamp', 'senderEmail', 'senderDisplayName']) &&
             hasOnlyAllowedFields(['subject', 'message', 'userId', 'timestamp', 'senderEmail', 'senderDisplayName']) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 300 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 10000 &&
             data.userId == request.auth.uid &&
             data.senderEmail is string && data.senderEmail.size() < 320 &&
             data.senderDisplayName is string && data.senderDisplayName.size() < 200 &&
             data.timestamp is timestamp &&
             contactSenderEmailMatchesToken(data);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidVote(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidVote(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /suggestions/{suggestionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSuggestion(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidSuggestion(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /customizations/{customizationId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidCustomization(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidCustomization(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidReport(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /contactMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidContactMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if true; // Certificates are public by design for sharing
      allow create: if isAuthenticated() && isValidCertificate(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidCertificate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /progress/{progressId} {
      // get() on a missing doc has no resource; allow so clients can safely check existence
      allow read: if isAuthenticated() && (
        !exists(/databases/$(database)/documents/progress/$(progressId)) ||
        isOwner(resource.data.userId)
      );
      allow create, update: if isAuthenticated() && isValidProgress(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    match /courseRatings/{ratingId} {
      allow read: if isAuthenticated() && (
        !exists(/databases/$(database)/documents/courseRatings/$(ratingId)) ||
        isOwner(resource.data.userId)
      );
      allow create, update: if isAuthenticated() && isValidCourseRating(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    match /quizAttempts/{attemptId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidQuizAttempt(request.resource.data);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if
        hasOnlyAllowedFields(['role', 'displayName', 'email']) &&
        (
          (isOwner(userId) && request.resource.data.role == 'user') ||
          (isAdmin() && request.resource.data.role in ['user', 'admin'])
        );
      allow update: if isAuthenticated() &&
        hasOnlyAllowedFields(['role', 'displayName', 'email']) &&
        (
          (isOwner(userId) && request.resource.data.role == resource.data.role) ||
          isAdmin()
        );
      // Account deletion: remove Firestore profile before Firebase Auth `deleteUser` (Auth alone does not delete this doc).
      allow delete: if isOwner(userId) || isAdmin();
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['userId', 'courseId', 'enrolledAt']) &&
        hasOnlyAllowedFields(['userId', 'courseId', 'enrolledAt']) &&
        data.userId == request.auth.uid &&
        data.courseId is string && data.courseId.size() > 0 && data.courseId.size() < 200 &&
        data.enrolledAt is timestamp;
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidEnrollment(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidEnrollment(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['type', 'title', 'message', 'courseId', 'status', 'createdAt']) &&
        data.type in ['course_update', 'topic_update', 'video_update', 'course_change', 'report_resolved'] &&
        data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
        data.message is string && data.message.size() > 0 && data.message.size() < 2000 &&
        data.courseId is string && data.courseId.size() > 0 && data.courseId.size() < 200 &&
        data.status in ['active', 'archived'] &&
        (data.createdAt == request.time || data.createdAt is timestamp) &&
        (!('userId' in data) || (data.userId is string && data.userId.size() > 0 && data.userId.size() < 200)) &&
        (!('moduleId' in data) || (data.moduleId is string && data.moduleId.size() < 200)) &&
        (!('lessonId' in data) || (data.lessonId is string && data.lessonId.size() < 200));
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAlert(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Admin-created inbox rows for a specific user (e.g. report resolved). Separate from `alerts`
    // so rules can scope reads to the recipient without exposing other users' docs.
    // Client uses FieldValue.serverTimestamp() for createdAt — in rules that value matches request.time,
    // not always `is timestamp`, so allow both (see Firebase rules + server timestamps).
    // Admin-only create: minimal shape checks (strict length caps have caused false denials).
    function isValidReportNoticeCreate(data) {
      return data.keys().hasAll(['forUserId', 'title', 'message', 'kind', 'createdAt']) &&
        data.forUserId is string && data.forUserId.size() > 0 && data.forUserId.size() < 256 &&
        data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
        data.message is string && data.message.size() > 0 && data.message.size() < 50000 &&
        data.kind == 'report_resolved' &&
        (!('lessonId' in data) || (data.lessonId is string && data.lessonId.size() > 0 && data.lessonId.size() < 4000));
    }

    match /reportNotices/{noticeId} {
      allow read: if isAuthenticated() && (
        resource.data.forUserId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin() && isValidReportNoticeCreate(request.resource.data);
      allow delete: if isAdmin();
      allow update: if false;
    }

    function isValidUserAlertStatePatch(data) {
      return (
        (data.keys().hasOnly(['readAlertIds', 'dismissedAlertIds', 'lastUpdated']) ||
          data.keys().hasOnly(['readAlertIds', 'dismissedAlertIds']) ||
          data.keys().hasOnly(['readAlertIds', 'lastUpdated']) ||
          data.keys().hasOnly(['dismissedAlertIds', 'lastUpdated']) ||
          data.keys().hasOnly(['readAlertIds']) ||
          data.keys().hasOnly(['dismissedAlertIds']) ||
          data.keys().hasOnly(['lastUpdated'])) &&
        (!('readAlertIds' in data) || data.readAlertIds is map) &&
        (!('dismissedAlertIds' in data) || data.dismissedAlertIds is map) &&
        (!('lastUpdated' in data) || data.lastUpdated is timestamp)
      );
    }

    match /userAlertState/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserAlertStatePatch(request.resource.data);
    }

    function isValidPublishedCourseWrite(data) {
      return data.keys().hasAll(['title', 'author', 'thumbnail', 'description', 'level', 'duration', 'rating', 'categories', 'skills', 'modules']) &&
        data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
        data.author is string && data.author.size() > 0 && data.author.size() < 200 &&
        data.thumbnail is string && data.thumbnail.size() > 0 && data.thumbnail.size() < 2000 &&
        data.description is string && data.description.size() < 20000 &&
        data.level in ['Beginner', 'Intermediate', 'Advanced', 'Proficient'] &&
        data.duration is string && data.duration.size() < 100 &&
        data.rating is number && data.rating >= 0 && data.rating <= 5 &&
        data.categories is list && data.categories.size() > 0 && data.categories.size() <= 40 &&
        data.skills is list && data.skills.size() <= 40 &&
        data.modules is list &&
        (!('authorBio' in data) || (data.authorBio is string && data.authorBio.size() < 20000)) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidLearningPathWrite(data) {
      return data.keys().hasAll(['title', 'courseIds']) &&
        data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
        data.courseIds is list && data.courseIds.size() <= 100 &&
        (!('description' in data) || (data.description is string && data.description.size() < 20000)) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp) &&
        (!('pathMindmap' in data) || data.pathMindmap is map);
    }

    match /learningPaths/{pathId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidLearningPathWrite(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidCatalogCategoryPresetsWrite(data) {
      return data.keys().hasAll(['mainPills', 'moreTopics']) &&
        data.mainPills is list && data.mainPills.size() > 0 && data.mainPills.size() <= 40 &&
        data.moreTopics is list && data.moreTopics.size() <= 40 &&
        (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /siteSettings/catalogCategoryPresets {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCatalogCategoryPresetsWrite(request.resource.data);
      allow delete: if false;
    }

    // Ordered Gemini model ids + per-model on/off for in-app AI. Falls back to build env when doc missing.
    // No recursion (Firestore rules disallow it): each index j is bool or past end of list (flags.size() <= j).
    function geminiEnabledFlagsAllBool(flags) {
      return (flags.size() <= 0 || flags[0] is bool) &&
        (flags.size() <= 1 || flags[1] is bool) &&
        (flags.size() <= 2 || flags[2] is bool) &&
        (flags.size() <= 3 || flags[3] is bool) &&
        (flags.size() <= 4 || flags[4] is bool) &&
        (flags.size() <= 5 || flags[5] is bool) &&
        (flags.size() <= 6 || flags[6] is bool) &&
        (flags.size() <= 7 || flags[7] is bool) &&
        (flags.size() <= 8 || flags[8] is bool) &&
        (flags.size() <= 9 || flags[9] is bool) &&
        (flags.size() <= 10 || flags[10] is bool) &&
        (flags.size() <= 11 || flags[11] is bool) &&
        (flags.size() <= 12 || flags[12] is bool) &&
        (flags.size() <= 13 || flags[13] is bool) &&
        (flags.size() <= 14 || flags[14] is bool) &&
        (flags.size() <= 15 || flags[15] is bool) &&
        (flags.size() <= 16 || flags[16] is bool) &&
        (flags.size() <= 17 || flags[17] is bool) &&
        (flags.size() <= 18 || flags[18] is bool) &&
        (flags.size() <= 19 || flags[19] is bool);
    }

    function isValidGeminiAiModelsWrite(data) {
      return data.keys().hasAll(['modelIds', 'updatedAt', 'enabledFlags']) &&
        data.keys().hasOnly(['modelIds', 'updatedAt', 'enabledFlags']) &&
        data.modelIds is list && data.modelIds.size() >= 1 && data.modelIds.size() <= 20 &&
        data.enabledFlags is list && data.enabledFlags.size() == data.modelIds.size() &&
        geminiEnabledFlagsAllBool(data.enabledFlags) &&
        data.updatedAt is timestamp;
    }

    match /siteSettings/geminiAiModels {
      allow read: if true;
      allow create, update: if isAdmin() && isValidGeminiAiModelsWrite(request.resource.data);
      allow delete: if false;
    }

    function isValidSiteBooleanToggleWrite(data) {
      return data.keys().hasAll(['enabled', 'updatedAt']) &&
        data.keys().hasOnly(['enabled', 'updatedAt']) &&
        data.enabled is bool &&
        data.updatedAt is timestamp;
    }

    match /siteSettings/learningAssistant {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSiteBooleanToggleWrite(request.resource.data);
      allow delete: if false;
    }

    match /siteSettings/learnerAiModels {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSiteBooleanToggleWrite(request.resource.data);
      allow delete: if false;
    }

    match /publishedCourses/{courseId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublishedCourseWrite(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
